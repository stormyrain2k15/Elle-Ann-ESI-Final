<?xml version="1.0" encoding="utf-8"?>
<!-- ElleCore.Shared — static library linked into every service.
     Hosts: ElleTypes, ElleSQLConn, ElleQueueIPC, ElleIdentityCore,
     ElleComposerClient, ElleLogger,
     ElleConfig, ElleServiceBase, ElleJsonExtract, DictionaryLoader,
     ElleSelfSurprise, vendored nlohmann::json.

     Tensor-free / token-free as of 2026-02. The transformer plumbing
     (WinHTTP API providers + llama.cpp embedding) was retired in favour
     of the Composer service (SVC_COMPOSER) which runs deterministic
     sentence composition. No additional link inputs required. -->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <ProjectGuid>{A1000000-0000-0000-0000-000000000001}</ProjectGuid>
    <RootNamespace>ElleCoreShared</RootNamespace>
    <ProjectName>ElleCore.Shared</ProjectName>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup Label="Configuration">
    <ConfigurationType>StaticLibrary</ConfigurationType>
    <UseDebugLibraries Condition="'$(Configuration)'=='Debug'">true</UseDebugLibraries>
    <UseDebugLibraries Condition="'$(Configuration)'=='Release'">false</UseDebugLibraries>
  </PropertyGroup>
  <PropertyGroup Label="Configuration" Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <PlatformToolset>v145</PlatformToolset>
  </PropertyGroup>
  <PropertyGroup Label="Configuration" Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <PlatformToolset>v145</PlatformToolset>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <!-- Pin the lib's name + extension so $(OutputFile) below is identical
       to the path consumers in Services/ link against. VS 2026 Insiders
       has been observed to leave $(TargetExt) empty for StaticLibrary
       projects when Microsoft.Cpp.props imports race the Configuration
       evaluation; setting them explicitly removes that race entirely. -->
  <PropertyGroup>
    <TargetName>ElleCore.Shared</TargetName>
    <TargetExt>.lib</TargetExt>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <PrecompiledHeader>NotUsing</PrecompiledHeader>
    </ClCompile>
    <Lib>
      <OutputFile>$(OutDir)$(TargetName)$(TargetExt)</OutputFile>
    </Lib>
  </ItemDefinitionGroup>
  <ItemGroup>
    <ClCompile Include="DictionaryLoader.cpp" />
    <ClCompile Include="ElleConfig.cpp" />
    <ClCompile Include="ElleCrypto.cpp" />
    <ClCompile Include="ElleEmbedding.cpp" />
    <ClCompile Include="ElleIdentityCore.cpp" />
    <ClCompile Include="ElleLogger.cpp" />
    <ClCompile Include="ElleQR.cpp" />
    <ClCompile Include="ElleQueueIPC.cpp" />
    <ClCompile Include="ElleSelfSurprise.cpp" />
    <ClCompile Include="ElleServerInfo.cpp" />
    <ClCompile Include="ElleServiceBase.cpp" />
    <ClCompile Include="ElleSQLConn.cpp" />
    <ClCompile Include="ElleSQLFallback.cpp" />
    <ClCompile Include="ElleLuaScalarReader.cpp" />
    <ClCompile Include="ElleDB_Queues.cpp" />
    <ClCompile Include="ElleDB_Domain.cpp" />
    <ClCompile Include="ElleDB_Content.cpp" />
    <ClCompile Include="ElleGameAccountDB.cpp" />
    <ClCompile Include="ElleUserContinuity.cpp" />
    <ClCompile Include="ElleLexicalAdmin.cpp" />
    <ClCompile Include="ElleUploadGuard.cpp" />
    <ClCompile Include="ElleShnVersionStore.cpp" />
    <ClCompile Include="ElleIntentLabelVocab_SqlLoader.cpp" />
    <ClCompile Include="ElleBeliefAdmin.cpp" />
    <ClCompile Include="ElleTypes.cpp" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="DictionaryLoader.h" />
    <ClInclude Include="ElleConfig.h" />
    <ClInclude Include="ElleCrypto.h" />
    <ClInclude Include="ElleEmbedding.h" />
    <ClInclude Include="ElleIdentityCore.h" />
    <ClInclude Include="ElleJsonExtract.h" />
    <ClInclude Include="ElleComposerClient.h" />
    <ClInclude Include="ElleLogger.h" />
    <ClInclude Include="ElleQR.h" />
    <ClInclude Include="ElleQueueIPC.h" />
    <ClInclude Include="ElleSelfSurprise.h" />
    <ClInclude Include="ElleServerInfo.h" />
    <ClInclude Include="ElleSQLConn.h" />
    <ClInclude Include="ElleSQLFallback.h" />
    <ClInclude Include="ElleLuaScalarReader.h" />
    <ClInclude Include="ElleGameAccountDB.h" />
    <ClInclude Include="ElleUserContinuity.h" />
    <ClInclude Include="ElleLexicalAdmin.h" />
    <ClInclude Include="ElleUploadGuard.h" />
    <ClInclude Include="ElleShnVersionStore.h" />
    <ClInclude Include="ElleIntentLabelVocab.h" />
    <ClInclude Include="ElleBeliefAdmin.h" />
    <ClInclude Include="ElleTypes.h" />
    <ClInclude Include="ElleWait.h" />
    <ClInclude Include="json.hpp" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>